<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modern Blog Platform</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',sans-serif}

body{
    height:100vh;
    display:flex;
    background:linear-gradient(135deg,#1f1c2c,#928dab);
    color:#fff;
}

.container{
    display:flex;
    width:100%;
}

.editor, .preview{
    width:50%;
    padding:20px;
}

.editor{
    background:rgba(0,0,0,0.4);
    backdrop-filter:blur(10px);
}

.preview{
    background:white;
    color:black;
    overflow-y:auto;
}

h2{
    margin-bottom:10px;
}

input, textarea{
    width:100%;
    margin-bottom:10px;
    padding:10px;
    border:none;
    border-radius:5px;
    outline:none;
}

textarea{
    height:300px;
    resize:none;
}

button{
    padding:10px 20px;
    border:none;
    background:#00c6ff;
    color:white;
    border-radius:5px;
    cursor:pointer;
}

.blog{
    max-width:600px;
    margin:auto;
}

.blog h1{
    margin-bottom:10px;
}

.blog small{
    color:gray;
}

.saved-posts{
    margin-top:20px;
}

.post-card{
    background:#f4f4f4;
    padding:10px;
    margin:10px 0;
    border-radius:5px;
    cursor:pointer;
}
</style>
</head>

<body>

<div class="container">

    <div class="editor">
        <h2>✍ Write Blog</h2>

        <input type="text" id="title" placeholder="Blog Title">
        <input type="text" id="author" placeholder="Author Name">
        <textarea id="content" placeholder="Write your blog..."></textarea>

        <button onclick="savePost()">Publish</button>

        <div class="saved-posts">
            <h3>Saved Posts</h3>
            <div id="posts"></div>
        </div>
    </div>

    <div class="preview">
        <h2>👀 Live Preview</h2>
        <div class="blog" id="preview"></div>
    </div>

</div>

<script>
const titleInput=document.getElementById("title");
const authorInput=document.getElementById("author");
const contentInput=document.getElementById("content");
const preview=document.getElementById("preview");

let posts=JSON.parse(localStorage.getItem("blogs"))||[];

function updatePreview(){
    preview.innerHTML=`
        <h1>${titleInput.value}</h1>
        <small>By ${authorInput.value}</small>
        <p>${contentInput.value.replace(/\n/g,'<br>')}</p>
    `;
}

[titleInput,authorInput,contentInput].forEach(el=>{
    el.addEventListener("input",updatePreview);
});

function savePost(){
    if(!titleInput.value||!contentInput.value) return alert("Fill all fields!");

    const post={
        title:titleInput.value,
        author:authorInput.value,
        content:contentInput.value
    };

    posts.push(post);
    localStorage.setItem("blogs",JSON.stringify(posts));

    titleInput.value="";
    authorInput.value="";
    contentInput.value="";
    preview.innerHTML="";

    loadPosts();
}

function loadPosts(){
    const container=document.getElementById("posts");
    container.innerHTML="";

    posts.forEach((p,i)=>{
        const div=document.createElement("div");
        div.classList.add("post-card");
        div.innerText=p.title;

        div.onclick=()=>{
            preview.innerHTML=`
                <h1>${p.title}</h1>
                <small>By ${p.author}</small>
                <p>${p.content.replace(/\n/g,'<br>')}</p>
            `;
        };

        container.appendChild(div);
    });
}

loadPosts();
</script>

</body>
</html>
